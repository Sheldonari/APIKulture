import { VerticalBox, HorizontalBox, LineEdit, ScrollView, ComboBox, TextEdit, ListView, Palette, Slider, CheckBox } from "std-widgets.slint";

/// Filled-style push button with sharp corners (Material `Button` uses a large pill radius).
component RectButton inherits Rectangle {
	in property <string> text: "";
	in property <bool> primary: false;
	in property <bool> enabled: true;
	/// Minimum height (toolbar rows override shorter to match CompactLineEdit).
	in property <length> min-btn-height: 30px;
	/// Minimum width; keep at least touch-target size unless parent overrides width/height.
	in property <length> min-btn-width: 30px;
	in property <length> pad-h: 12px;
	in property <length> pad-v: 3px;
	callback clicked;

	border-width: 0px;
	border-radius: 3px;
	clip: true;
	min-height: min-btn-height;
	min-width: min-btn-width;
	horizontal-stretch: 0;
	vertical-stretch: 0;

	states [
		disabled when !root.enabled: {
			root.opacity: 0.38;
		}
	]

	background: root.primary ? Palette.accent-background : Palette.control-background;

	HorizontalLayout {
		padding-left: pad-h;
		padding-right: pad-h;
		padding-top: pad-v;
		padding-bottom: pad-v;
		alignment: center;
		Text {
			text: root.text;
			color: root.primary ? Palette.accent-foreground : Palette.control-foreground;
			vertical-alignment: center;
			horizontal-alignment: center;
			font-weight: 500;
		}
	}

	TouchArea {
		enabled: root.enabled;
		width: 100%;
		height: 100%;
		clicked => {
			root.clicked();
		}
	}
}

/// Toolbar-sized button that shows an icon (same visual language as `RectButton`).
component IconRectButton inherits Rectangle {
	in property <image> icon;
	in property <length> min-btn-size: 26px;
	callback clicked;

	min-width: min-btn-size;
	min-height: min-btn-size;
	max-height: min-btn-size;
	border-width: 1px;
	border-color: Palette.border;
	border-radius: 3px;
	clip: true;
	horizontal-stretch: 0;
	vertical-stretch: 0;

	background: Palette.alternate-background;

	states [
		hover when ta.has-hover: {
			background: Palette.control-background;
		}
	]

	Image {
		source: root.icon;
		width: 16px;
		height: 16px;
		x: (parent.width - self.width) / 2;
		y: (parent.height - self.height) / 2;
		colorize: Palette.control-foreground;
	}

	ta := TouchArea {
		width: 100%;
		height: 100%;
		mouse-cursor: pointer;
		clicked => {
			root.clicked();
		}
	}
}

/// Single-line field shorter than Material LineEdit default (~56px).
component CompactLineEdit inherits LineEdit {
	min-height: 28px;
	max-height: 28px;
	vertical-stretch: 0;
}

/// Draggable vertical bar; `panel-width` is the width of the panel to the left of this splitter.
component VerticalSplitter inherits Rectangle {
	in property <length> min-panel-width: 0px;
	in property <length> max-panel-width: 10000px;
	in-out property <length> panel-width;
	width: 4px;
	vertical-stretch: 1;
	background: ta.has-hover ? Palette.control-background : Palette.border;

	private property <length> drag-start-width: 0px;

	ta := TouchArea {
		width: parent.width;
		height: parent.height;
		mouse-cursor: MouseCursor.ew-resize;
		moved => {
			root.panel-width = Math.max(root.min-panel-width, Math.min(root.max-panel-width,
				root.drag-start-width + (self.mouse-x - self.pressed-x)));
		}
		pointer-event(event) => {
			if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
				root.drag-start-width = root.panel-width;
			}
		}
	}
}

/// Draggable horizontal bar; `panel-height` is the height of the panel above this splitter.
component HorizontalSplitter inherits Rectangle {
	in property <length> min-panel-height: 0px;
	in property <length> max-panel-height: 10000px;
	in-out property <length> panel-height;
	height: 4px;
	horizontal-stretch: 1;
	background: ta.has-hover ? Palette.control-background : Palette.border;

	private property <length> drag-start-height: 0px;

	ta := TouchArea {
		width: parent.width;
		height: parent.height;
		mouse-cursor: MouseCursor.ns-resize;
		moved => {
			root.panel-height = Math.max(root.min-panel-height, Math.min(root.max-panel-height,
				root.drag-start-height + (self.mouse-y - self.pressed-y)));
		}
		pointer-event(event) => {
			if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
				root.drag-start-height = root.panel-height;
			}
		}
	}
}

/// Response font dropdown; closed row shows the font name centered between horizontal padding.
/// When `embed-list` is true, the list opens inline (no nested `PopupWindow`) — required inside another `PopupWindow` whose default close policy would dismiss the parent on click.
component ResponseFontPicker inherits Rectangle {
	in property <[string]> fonts;
	in-out property <int> current-index: 0;
	in property <bool> embed-list: false;
	callback picked(int);

	private property <length> row-h: 28px;
	private property <bool> list-open: false;

	min-width: 160px;
	min-height: embed-list ? (list-open ? 28px + min(6 * row-h + 8px, fonts.length * row-h + 8px) : 28px) : 28px;
	max-height: embed-list ? 10000px : 28px;
	vertical-stretch: 0;
	horizontal-stretch: 1;
	max-width: 320px;
	border-width: 1px;
	border-color: Palette.border;
	border-radius: 4px;
	background: Palette.control-background;
	clip: false;

	VerticalLayout {
		spacing: 0px;
		padding: 0px;

		Rectangle {
			height: 28px;
			vertical-stretch: 0;
			background: transparent;

			HorizontalLayout {
				padding-left: 10px;
				padding-right: 8px;
				spacing: 4px;
				Text {
					text: root.current-index >= 0 && root.current-index < root.fonts.length ? root.fonts[root.current-index] : "";
					horizontal-alignment: center;
					vertical-alignment: center;
					horizontal-stretch: 1;
					color: Palette.control-foreground;
					font-size: 12px;
					overflow: elide;
				}
				Text {
					text: root.list-open ? "▴" : "▾";
					vertical-alignment: center;
					font-size: 11px;
					color: Palette.control-foreground;
				}
			}

			TouchArea {
				width: 100%;
				height: 100%;
				clicked => {
					if root.embed-list {
						root.list-open = !root.list-open;
					} else {
						popup.show();
					}
				}
			}
		}

		if root.embed-list && root.list-open: Rectangle {
			vertical-stretch: 0;
			height: min(6 * root.row-h + 8px, root.fonts.length * root.row-h + 8px);
			background: Palette.alternate-background;
			border-width: 1px;
			border-color: Palette.border;
			border-radius: 4px;

			ScrollView {
				width: 100%;
				height: 100%;
				VerticalLayout {
					padding: 4px;
					alignment: start;
					for label[idx] in root.fonts: embed-row := TouchArea {
						height: root.row-h;
						width: 100%;
						Rectangle {
							width: 100%;
							height: 100%;
							background: idx == root.current-index ? Palette.selection-background : (embed-row.has-hover ? Palette.control-background : transparent);
							border-radius: 3px;
							Text {
								text: label;
								font-size: 12px;
								color: Palette.foreground;
								x: 8px;
								y: (parent.height - self.height) / 2;
								width: parent.width - 16px;
								overflow: elide;
							}
						}
						clicked => {
							root.current-index = idx;
							root.picked(idx);
							root.list-open = false;
						}
					}
				}
			}
		}
	}

	popup := PopupWindow {
		x: 0px;
		y: root.height + 2px;
		width: max(root.width, 200px);
		height: min(6 * root.row-h + 8px, root.fonts.length * root.row-h + 8px);
		close-policy: close-on-click-outside;

		Rectangle {
			width: 100%;
			height: 100%;
			background: Palette.alternate-background;
			border-width: 1px;
			border-color: Palette.border;
			border-radius: 4px;

			ScrollView {
				width: 100%;
				height: 100%;
				VerticalLayout {
					padding: 4px;
					alignment: start;
					for label[idx] in root.fonts: row-touch := TouchArea {
						height: root.row-h;
						width: 100%;
						Rectangle {
							width: 100%;
							height: 100%;
							background: idx == root.current-index ? Palette.selection-background : (row-touch.has-hover ? Palette.control-background : transparent);
							border-radius: 3px;
							Text {
								text: label;
								font-size: 12px;
								color: Palette.foreground;
								x: 8px;
								y: (parent.height - self.height) / 2;
								width: parent.width - 16px;
								overflow: elide;
							}
						}
						clicked => {
							root.current-index = idx;
							root.picked(idx);
							popup.close();
						}
					}
				}
			}
		}
	}
}

/// Syntax-highlighted response body (read-only). Token kind: 0 punct, 1 string, 2 number, 3 keyword, 4 key.
export struct TokenSpan {
	text: string,
	token-kind: int,
}

export struct ResponseLine {
	spans: [TokenSpan],
}

component ResponseBodyViewer inherits Rectangle {
	in property <[ResponseLine]> lines;
	in property <string> font-family: "monospace";
	in property <length> font-size: 12 * 1px;

	function json-token-color(kind: int) -> color {
		if (Palette.color-scheme == ColorScheme.dark) {
			if (kind == 1) { return #98c379; }
			if (kind == 2) { return #d19a66; }
			if (kind == 3) { return #c678dd; }
			if (kind == 4) { return #e06c75; }
			return #abb2bf;
		}
		if (kind == 1) { return #0d7d4d; }
		if (kind == 2) { return #b45309; }
		if (kind == 3) { return #6f42c1; }
		if (kind == 4) { return #c92a2a; }
		return #24292f;
	}

	border-width: 1px;
	border-color: Palette.border;
	border-radius: 4px;
	background: Palette.alternate-background;
	clip: true;
	vertical-stretch: 1;
	min-height: 80px;

	ListView {
		width: 100%;
		height: 100%;
		for line in root.lines: HorizontalLayout {
			alignment: start;
			spacing: 0px;
			padding-top: 1px;
			padding-bottom: 1px;
			min-height: root.font-size * 1.4;
			for span in line.spans: Text {
				text: span.text;
				color: root.json-token-color(span.token-kind);
				font-family: root.font-family;
				font-size: root.font-size;
				vertical-alignment: top;
				overflow: clip;
			}
		}
	}
}

export global AppLogic {
	callback send-request();
	callback cancel-request();
	callback request-url-accepted();
	callback request-url-edited();
	callback copy-request-url();
	callback copy-response-body();
	callback select-collection(int);
	callback select-request(int);
	callback new-collection();
	callback delete-collection();
	callback new-request();
	callback delete-request();
	callback duplicate-request();
	callback save-collections();
	callback import-openapi();
	callback import-openapi-url();
	callback environment-changed(string);
	callback new-environment();
	callback delete-environment();
	callback commit-environment-name();
	callback commit-environment-variables();
	callback request-body-edited();
	/// Persist method / body-kind when the user changes the HTTP method or body format combo.
	callback request-method-changed();
	callback request-body-kind-changed();
	callback query-param-key-edited(int, string);
	callback query-param-value-edited(int, string);
	callback query-param-enabled-changed(int, bool);
	callback add-query-param();
	callback remove-query-param(int);
	callback request-header-key-edited(int, string);
	callback request-header-value-edited(int, string);
	callback request-header-enabled-changed(int, bool);
	callback add-request-header();
	callback remove-request-header(int);
	callback commit-collection-name();
	callback commit-request-name();
	callback response-jsonpath-changed();
	callback response-font-selected(int);
	callback adjust-response-font-size(int);
	callback commit-response-font-size(float);
	callback collection-delete-dialog-cancel();
	callback collection-delete-dialog-confirm();
	callback request-elapsed-tick();

	in-out property <string> collection-name-edit: "";
	in-out property <string> request-name-edit: "";

	in property <[string]> collection-names: [];
	in property <[string]> request-names: [];
	in property <int> selected-collection-index: 0;
	in property <int> selected-request-index: 0;

	in-out property <string> active-environment-name: "Default";
	in-out property <string> environment-name-edit: "";
	in-out property <string> environment-base-url: "";
	in-out property <string> environment-variables: "";
	in property <[string]> environment-names: [];

	in property <[string]> query-param-keys: [];
	in property <[string]> query-param-values: [];
	in property <[bool]> query-param-enabled: [];

	in property <[string]> request-header-keys: [];
	in property <[string]> request-header-values: [];
	in property <[bool]> request-header-enabled: [];

	in-out property <string> method: "GET";
	/// 0 = JSON, 1 = plain text, 2 = application/x-www-form-urlencoded (unless Headers override Content-Type).
	in-out property <int> request-body-kind-index: 0;
	in-out property <string> url: "";
	/// Full URL after base URL, variables, and query-parameter table (matches the HTTP request).
	in property <string> resolved-request-url: "";
	in-out property <string> request-body: "";
	in property <string> response-status: "";
	/// Live and final request duration, e.g. "1.23 s"; empty when idle / after switching request.
	in property <string> request-elapsed: "";
	in property <string> response-headers: "";
	in-out property <string> response-jsonpath: "";
	in-out property <string> response-body: "";
	in property <[ResponseLine]> response-body-lines: [];
	in-out property <string> response-body-font-family: "monospace";
	in-out property <float> response-body-font-size: 12;
	in property <[string]> response-font-names: [];
	in-out property <int> response-font-index: 0;
	in property <bool> loading: false;
	/// Result or error message after “Import OpenAPI”; empty when unused.
	in-out property <string> import-status: "";
	/// OpenAPI JSON document URL for “Fetch”.
	in-out property <string> openapi-import-url: "";
	in-out property <bool> collection-delete-dialog-open: false;
	in-out property <bool> collection-delete-dialog-info-only: false;
	in-out property <string> collection-delete-dialog-text: "";
}

export component MainWindow inherits Window {
	// Theme comes from Palette (std-widgets); `unknown` follows OS. Override from C++ via
	// `set_window_color_scheme` or env `APIKULTURE_COLOR_SCHEME` (light|dark|system|auto).
	/// POST, PUT, PATCH, DELETE may carry a body; GET/HEAD/OPTIONS do not (RFC practice).
	function method-allows-body(m: string) -> bool {
		m == "POST" || m == "PUT" || m == "PATCH" || m == "DELETE"
	}

	in-out property <ColorScheme> window-color-scheme <=> Palette.color-scheme;
	background: Palette.background;
	icon: @image-url("icons/apikulture.svg");
	title: "APIkulture";
	preferred-width: 1100px;
	preferred-height: 720px;
	min-width: 1000px;
	min-height: 640px;

	in-out property <length> collection-panel-width: 240px;
	in-out property <length> request-panel-width: 420px;
	in-out property <length> sidebar-collections-height: 200px;
	/// Requests block (title + list + New/Dup/Del) above the splitter; below: Save / import / environment.
	in-out property <length> sidebar-requests-section-height: 180px;
	/// Reserved height for the import/environment/variables block below the sidebar splitters.
	private property <length> sidebar-environment-min-height: 260px;
	/// Height of the query-parameters block (label + list + “+ param”) above the horizontal splitter.
	/// Default must leave room for headers + body on short windows (min-height 640px); drag splitters to expand.
	in-out property <length> request-query-panel-height: 200px;
	/// Height of the request headers block (label + grid + “+ header”) above the splitter before the body.
	in-out property <length> request-headers-panel-height: 80px;
	/// Height of the response headers block (label + scroll area) above the horizontal splitter.
	in-out property <length> response-headers-panel-height: 120px;

	Timer {
		interval: 100ms;
		running: AppLogic.loading;
		triggered() => {
			AppLogic.request-elapsed-tick();
		}
	}

	// Keyboard zoom is scoped to the Response column only (see `response-key-scope`) so the
	// request Body TextEdit is not under a window-wide FocusScope (which still breaks focus).
	/// Stack main UI + modal in one layer so `width/height: 100%` on the dialog refers to the
	/// full client area. As a third `Window` child, the overlay’s layout slot was ~0×0 (invisible).
	Rectangle {
		width: 100%;
		height: 100%;
		vertical-stretch: 1;
		horizontal-stretch: 1;

		HorizontalBox {
			// std-widgets HorizontalBox defaults to StyleMetrics.layout-padding (~16px) on all sides.
			spacing: 0;
			padding: 0px;

			// --- Left sidebar: collections + requests (Palette follows system light/dark) ---
		Rectangle {
			width: collection-panel-width;
			vertical-stretch: 1;
			background: Palette.alternate-background;

			VerticalBox {
				// std-widgets layouts default to StyleMetrics.layout-padding (16px); override explicitly.
				padding-top: 0px;
				padding-left: 0px;
				padding-right: 3px;
				padding-bottom: 4px;
				spacing: 0px;

				VerticalBox {
					height: sidebar-collections-height;
					vertical-stretch: 0;
					spacing: 4px;

					Text {
						text: "Collections";
						font-size: 13px;
						font-weight: 700;
						color: Palette.foreground;
					}
					ListView {
						min-height: 30px;
						vertical-stretch: 1;
						for name[index] in AppLogic.collection-names: col-touch := TouchArea {
							height: 28px;
							Rectangle {
								width: parent.width;
								height: parent.height;
								background: index == AppLogic.selected-collection-index ? Palette.selection-background : (col-touch.has-hover ? Palette.control-background : transparent);
								border-radius: 3px;
								if index == AppLogic.selected-collection-index: CompactLineEdit {
									placeholder-text: "Name";
									text <=> AppLogic.collection-name-edit;
									font-size: 13px;
									x: 4px;
									y: parent.height / 2 - self.height / 2;
									width: parent.width - 8px;
									min-height: 20px;
									max-height: 24px;
									accepted => {
										AppLogic.commit-collection-name();
									}
								}
								if index != AppLogic.selected-collection-index: Text {
									text: name;
									overflow: elide;
									font-size: 13px;
									color: Palette.foreground;
									x: 6px;
									y: parent.height / 2 - self.height / 2;
								}
							}
							clicked => {
								AppLogic.select-collection(index);
							}
						}
					}
					HorizontalBox {
						padding: 0px;
						spacing: 3px;
						RectButton {
							text: "+ Collection";
							horizontal-stretch: 1;
							clicked => {
								AppLogic.new-collection();
							}
						}
						RectButton {
							text: "Del";
							min-btn-width: 36px;
							pad-h: 6px;
							enabled: AppLogic.collection-names.length > 1;
							clicked => {
								AppLogic.delete-collection();
							}
						}
					}
				}

				HorizontalSplitter {
					panel-height <=> sidebar-collections-height;
					min-panel-height: 120px;
					max-panel-height: Math.max(120px, root.height - sidebar-requests-section-height - sidebar-environment-min-height - 12px);
				}

				VerticalBox {
					height: sidebar-requests-section-height;
					vertical-stretch: 0;
					spacing: 4px;

					Text {
						text: "Requests";
						font-size: 13px;
						font-weight: 700;
						color: Palette.foreground;
					}
					ListView {
						min-height: 100px;
						vertical-stretch: 1;
						for name[index] in AppLogic.request-names: req-touch := TouchArea {
							height: 28px;
							Rectangle {
								width: parent.width;
								height: parent.height;
								background: index == AppLogic.selected-request-index ? Palette.selection-background : (req-touch.has-hover ? Palette.control-background : transparent);
								border-radius: 3px;
								if index == AppLogic.selected-request-index: CompactLineEdit {
									placeholder-text: "Name";
									text <=> AppLogic.request-name-edit;
									font-size: 13px;
									x: 4px;
									y: parent.height / 2 - self.height / 2;
									width: parent.width - 8px;
									min-height: 20px;
									max-height: 24px;
									accepted => {
										AppLogic.commit-request-name();
									}
								}
								if index != AppLogic.selected-request-index: Text {
									text: name;
									overflow: elide;
									font-size: 13px;
									color: Palette.foreground;
									x: 6px;
									y: parent.height / 2 - self.height / 2;
								}
							}
							clicked => {
								AppLogic.select-request(index);
							}
						}
					}

					HorizontalBox {
						padding: 0px;
						spacing: 3px;
						RectButton {
							text: "New";
							clicked => {
								AppLogic.new-request();
							}
						}
						RectButton {
							text: "Dup";
							clicked => {
								AppLogic.duplicate-request();
							}
						}
						RectButton {
							text: "Del";
							clicked => {
								AppLogic.delete-request();
							}
						}
						RectButton {
							text: "Save all";
							clicked => {
								AppLogic.save-collections();
							}
						}
					}
				}

				HorizontalSplitter {
					panel-height <=> sidebar-requests-section-height;
					min-panel-height: 140px;
					max-panel-height: Math.max(140px, root.height - sidebar-collections-height - sidebar-environment-min-height - 12px);
				}
				VerticalBox {
					vertical-stretch: 1;
					spacing: 2px;

					Text {
						vertical-stretch: 0;
						text: "OpenAPI URL (JSON)";
						font-size: 11px;
						color: Palette.foreground;
					}
					HorizontalBox {
						vertical-stretch: 0;
						padding: 0px;
						spacing: 3px;
						CompactLineEdit {
							placeholder-text: "https://api.example.com/openapi.json";
							text <=> AppLogic.openapi-import-url;
							horizontal-stretch: 1;
							font-size: 12px;
						}
						RectButton {
							text: "Fetch";
							clicked => {
								AppLogic.import-openapi-url();
							}
						}
						RectButton {
							text: "...";
							clicked => {
								AppLogic.import-openapi();
							}
						}
					}

					if AppLogic.import-status != "": Text {
						vertical-stretch: 0;
						text: AppLogic.import-status;
						font-size: 10px;
						color: Palette.foreground;
						wrap: word-wrap;
					}

					Text {
						vertical-stretch: 0;
						text: "Environment";
						font-size: 13px;
						font-weight: 700;
						color: Palette.foreground;
					}
					ComboBox {
						vertical-stretch: 0;
						model: AppLogic.environment-names;
						current-value <=> AppLogic.active-environment-name;
						selected(name) => {
							AppLogic.environment-changed(name);
						}
						min-width: 120px;
						min-height: 28px;
						max-height: 30px;
						horizontal-stretch: 1;
					}
					CompactLineEdit {
						placeholder-text: "Rename environment";
						text <=> AppLogic.environment-name-edit;
						font-size: 13px;
						accepted => {
							AppLogic.commit-environment-name();
						}
					}
					Text {
						vertical-stretch: 0;
						text: "Base URL";
						font-size: 11px;
						color: Palette.foreground;
					}
					CompactLineEdit {
						placeholder-text: "https://api.dev.example.com";
						text <=> AppLogic.environment-base-url;
						font-size: 12px;
						horizontal-stretch: 1;
						edited => {
							AppLogic.commit-environment-variables();
						}
					}
					Text {
						vertical-stretch: 0;
						text: "Request URL can be a path (/v1/users); full URLs skip the base.";
						font-size: 10px;
						color: Palette.foreground;
						wrap: word-wrap;
					}
					HorizontalBox {
						vertical-stretch: 0;
						padding: 0px;
						spacing: 3px;
						RectButton {
							text: "+ Env";
							clicked => {
								AppLogic.new-environment();
							}
						}
						RectButton {
							text: "Del env";
							clicked => {
								AppLogic.delete-environment();
							}
						}
					}
					Text {
						vertical-stretch: 0;
						text: "Variables";
						font-size: 13px;
						font-weight: 700;
						color: Palette.foreground;
					}
					Text {
						vertical-stretch: 0;
						text: "Shared by all environments in this collection. One KEY=value per line; use {{KEY}} in URL, headers, query params, or body. Lines starting with # are comments.";
						font-size: 10px;
						color: Palette.foreground;
						wrap: word-wrap;
					}
					// All surplus height in the environment block belongs to the variables editor.
					TextEdit {
						horizontal-stretch: 1;
						vertical-stretch: 1;
						min-height: 96px;
						text <=> AppLogic.environment-variables;
						font-family: "monospace";
						font-size: 12px;
						wrap: word-wrap;
						placeholder-text: "api_key=\nuser_id=42";
						edited => {
							AppLogic.commit-environment-variables();
						}
					}
				}
			}
		}

		VerticalSplitter {
			panel-width <=> collection-panel-width;
			min-panel-width: 180px;
			max-panel-width: 560px;
		}

		// --- URL bar (full width above Request | Response), then two columns ---
		VerticalBox {
			padding-top: 0px;
			padding-left: 3px;
			padding-right: 0px;
			padding-bottom: 0px;
			spacing: 4px;
			horizontal-stretch: 1;
			vertical-stretch: 1;

			VerticalBox {
				padding: 0px;
				spacing: 3px;

				HorizontalBox {
					padding: 0px;
					spacing: 4px;
					alignment: stretch;

					ComboBox {
						current-value <=> AppLogic.method;
						model: ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"];
						width: 110px;
						min-height: 28px;
						max-height: 30px;
						selected => {
							AppLogic.request-method-changed();
						}
					}

					CompactLineEdit {
						placeholder-text: "/v1/resource or https://host/path";
						text <=> AppLogic.url;
						horizontal-stretch: 1;
						edited => {
							AppLogic.request-url-edited();
						}
						accepted => {
							AppLogic.request-url-accepted();
						}
					}

					RectButton {
						text: AppLogic.loading ? "Cancel" : "Send";
						primary: !AppLogic.loading;
						min-btn-height: 28px;
						pad-v: 2px;
						pad-h: 14px;
						clicked => {
							if (AppLogic.loading) {
								AppLogic.cancel-request();
							} else {
								AppLogic.send-request();
							}
						}
					}
				}

				HorizontalBox {
					padding: 0px;
					spacing: 4px;
					alignment: stretch;

					Text {
						text: AppLogic.resolved-request-url;
						font-size: 11px;
						color: Palette.foreground;
						wrap: word-wrap;
						horizontal-stretch: 1;
						vertical-alignment: center;
					}

					IconRectButton {
						vertical-stretch: 0;
						icon: @image-url("icons/copy.svg");
						clicked => {
							AppLogic.copy-request-url();
						}
					}
				}
			}

			HorizontalBox {
				padding: 0px;
				spacing: 4px;
				vertical-stretch: 1;
				horizontal-stretch: 1;

				VerticalBox {
					padding: 0px;
					spacing: 4px;
					width: request-panel-width;
					horizontal-stretch: 0;
					vertical-stretch: 1;

					Text {
						text: "Request";
						font-size: 14px;
						font-weight: 700;
					}

					VerticalBox {
						height: request-query-panel-height;
						vertical-stretch: 0;
						spacing: 0px;
						padding: 0px;

						Text {
							text: "Query parameters";
							font-size: 11px;
						}
						ScrollView {
							vertical-stretch: 1;
							horizontal-stretch: 1;
							min-height: 32px;
							VerticalBox {
								width: 100%;
								horizontal-stretch: 1;
								vertical-stretch: 0;
								alignment: start;
								spacing: 0px;
								padding: 0px;
								GridLayout {
									width: 100%;
									vertical-stretch: 0;
									spacing: 4px;
									Row {
										Text {
											text: "On";
											font-size: 11px;
											font-weight: 600;
											vertical-alignment: top;
											min-width: 28px;
										}
										Text {
											text: "Name";
											font-size: 11px;
											font-weight: 600;
											vertical-alignment: top;
											horizontal-stretch: 1;
										}
										Text {
											text: "Value";
											font-size: 11px;
											font-weight: 600;
											vertical-alignment: top;
											horizontal-stretch: 1;
										}
										Text {
											text: "";
											min-width: 28px;
										}
									}
									for key[idx] in AppLogic.query-param-keys: Row {
										CheckBox {
											checked: AppLogic.query-param-enabled[idx];
											min-width: 28px;
											min-height: 28px;
											toggled => {
												AppLogic.query-param-enabled-changed(idx, self.checked);
											}
										}
										CompactLineEdit {
											font-family: AppLogic.response-body-font-family;
											font-size: AppLogic.response-body-font-size * 1px;
											placeholder-text: "name";
											text: key;
											horizontal-stretch: 1;
											edited => {
												AppLogic.query-param-key-edited(idx, self.text);
											}
											accepted => {
												AppLogic.query-param-key-edited(idx, self.text);
											}
										}
										CompactLineEdit {
											font-family: AppLogic.response-body-font-family;
											font-size: AppLogic.response-body-font-size * 1px;
											placeholder-text: "value";
											text: AppLogic.query-param-values[idx];
											horizontal-stretch: 1;
											edited => {
												AppLogic.query-param-value-edited(idx, self.text);
											}
											accepted => {
												AppLogic.query-param-value-edited(idx, self.text);
											}
										}
										RectButton {
											text: "×";
											min-btn-height: 28px;
											min-btn-width: 28px;
											pad-h: 4px;
											pad-v: 2px;
											clicked => {
												AppLogic.remove-query-param(idx);
											}
										}
									}
								}
							}
						}
						RectButton {
							text: "+ param";
							clicked => {
								AppLogic.add-query-param();
							}
						}
					}

					HorizontalSplitter {
						panel-height <=> request-query-panel-height;
						min-panel-height: 30px;
						max-panel-height: 10000px;
					}

					VerticalBox {
						vertical-stretch: 1;
						spacing: 4px;
						padding: 0px;

						// Body only for methods that commonly carry a payload; stored when switching methods.
						if method-allows-body(AppLogic.method): VerticalBox {
							vertical-stretch: 1;
							min-height: 28px;
							spacing: 4px;
							padding: 0px;

							HorizontalBox {
								padding: 0px;
								spacing: 8px;
								Text {
									text: "Body";
									font-size: 11px;
									vertical-alignment: center;
								}
								ComboBox {
									horizontal-stretch: 1;
									min-width: 200px;
									min-height: 28px;
									max-height: 30px;
									model: ["JSON", "Plain text", "Form (URL-encoded)"];
									current-index <=> AppLogic.request-body-kind-index;
									selected => {
										AppLogic.request-body-kind-changed();
									}
								}
							}
							Text {
								text: "Default Content-Type follows Format unless you set Content-Type under Headers.";
								font-size: 10px;
								color: Palette.foreground;
								wrap: word-wrap;
							}
							TextEdit {
								horizontal-stretch: 1;
								vertical-stretch: 1;
								min-height: 40px;
								text <=> AppLogic.request-body;
								wrap: word-wrap;
								font-size: 12px;
								font-family: "monospace";
								placeholder-text: "Request payload (JSON object, plain text, or urlencoded pairs)";
								edited => {
									AppLogic.request-body-edited();
								}
							}
						}
						if !method-allows-body(AppLogic.method): Text {
							text: "Request body is not used for GET, HEAD, or OPTIONS. Use Query parameters or the URL path.";
							font-size: 11px;
							color: Palette.foreground;
							wrap: word-wrap;
						}

						VerticalBox {
							vertical-stretch: 1;
							spacing: 4px;
							padding: 0px;

							Text {
								vertical-stretch: 0;
								text: "Headers ({{var}} in name or value)";
								font-size: 11px;
							}
							ScrollView {
								vertical-stretch: 1;
								horizontal-stretch: 1;
								min-height: 32px;
								VerticalBox {
									width: 100%;
									horizontal-stretch: 1;
									vertical-stretch: 0;
									alignment: start;
									spacing: 0px;
									padding: 0px;
									GridLayout {
										width: 100%;
										vertical-stretch: 0;
										spacing: 4px;
										Row {
											Text {
												text: "On";
												font-size: 11px;
												font-weight: 600;
												vertical-alignment: top;
												min-width: 28px;
											}
											Text {
												text: "Name";
												font-size: 11px;
												font-weight: 600;
												vertical-alignment: top;
												horizontal-stretch: 1;
											}
											Text {
												text: "Value";
												font-size: 11px;
												font-weight: 600;
												vertical-alignment: top;
												horizontal-stretch: 1;
											}
											Text {
												text: "";
												min-width: 28px;
											}
										}
										for _[idx] in AppLogic.request-header-keys: Row {
											CheckBox {
												checked: AppLogic.request-header-enabled[idx];
												min-width: 28px;
												min-height: 28px;
												toggled => {
													AppLogic.request-header-enabled-changed(idx, self.checked);
												}
											}
											CompactLineEdit {
												font-family: AppLogic.response-body-font-family;
												font-size: AppLogic.response-body-font-size * 1px;
												placeholder-text: "name";
												// Same indexed binding as values — loop alias alone can fail to sync edits in some Slint versions.
												text: AppLogic.request-header-keys[idx];
												horizontal-stretch: 1;
												edited => {
													AppLogic.request-header-key-edited(idx, self.text);
												}
												accepted => {
													AppLogic.request-header-key-edited(idx, self.text);
												}
											}
											CompactLineEdit {
												font-family: AppLogic.response-body-font-family;
												font-size: AppLogic.response-body-font-size * 1px;
												placeholder-text: "value";
												text: AppLogic.request-header-values[idx];
												horizontal-stretch: 1;
												edited => {
													AppLogic.request-header-value-edited(idx, self.text);
												}
												accepted => {
													AppLogic.request-header-value-edited(idx, self.text);
												}
											}
											RectButton {
												text: "×";
												min-btn-height: 28px;
												min-btn-width: 28px;
												pad-h: 4px;
												pad-v: 2px;
												clicked => {
													AppLogic.remove-request-header(idx);
												}
											}
										}
									}
								}
							}
							RectButton {
								text: "+ header";
								vertical-stretch: 0;
								horizontal-stretch: 1;
								clicked => {
									AppLogic.add-request-header();
								}
							}
						}
					}
				}

				VerticalSplitter {
					panel-width <=> request-panel-width;
					min-panel-width: 200px;
					max-panel-width: 10000px;
				}

				response-key-scope := FocusScope {
					horizontal-stretch: 1;
					min-width: 200px;
					vertical-stretch: 1;
					focus-on-click: false;
					capture-key-pressed(event) => {
						if (event.modifiers.control) {
							if (event.text == "-") {
								AppLogic.adjust-response-font-size(-1);
								return accept;
							}
							if (event.text == "+" || event.text == "=") {
								AppLogic.adjust-response-font-size(1);
								return accept;
							}
						}
						reject
					}

					VerticalBox {
						padding: 0px;
						spacing: 4px;
						horizontal-stretch: 1;
						min-width: 200px;
						vertical-stretch: 1;

						HorizontalBox {
							padding: 0px;
							spacing: 6px;
							Text {
								text: "Response";
								font-size: 14px;
								font-weight: 700;
								vertical-alignment: center;
								horizontal-stretch: 1;
							}
						Rectangle {
							width: 40px;
							height: 28px;
							vertical-stretch: 0;
							RectButton {
								text: "Aa";
								min-btn-height: 28px;
								min-btn-width: 28px;
								pad-h: 6px;
								pad-v: 4px;
								width: 100%;
								height: 100%;
								clicked => {
									response-font-settings-popup.show();
								}
							}
							response-font-settings-popup := PopupWindow {
								x: 0px;
								y: parent.height + 4px;
								width: 288px;
								close-policy: close-on-click-outside;

								Rectangle {
									width: 100%;
									height: 100%;
									background: Palette.alternate-background;
									border-width: 1px;
									border-color: Palette.border;
									border-radius: 8px;

									VerticalBox {
										padding: 12px;
										spacing: 10px;
										width: 100%;

										Text {
											text: "Response font";
											font-size: 14px;
											font-weight: 700;
											color: Palette.foreground;
										}
										Text {
											text: "Typeface";
											font-size: 11px;
											color: Palette.foreground;
										}
										ResponseFontPicker {
											embed-list: true;
											fonts: AppLogic.response-font-names;
											current-index <=> AppLogic.response-font-index;
											horizontal-stretch: 1;
											min-width: 160px;
											max-width: 264px;
											width: 100%;
											picked(idx) => {
												AppLogic.response-font-selected(idx);
											}
										}
										HorizontalBox {
											spacing: 8px;
											Text {
												text: "Size";
												font-size: 11px;
												vertical-alignment: center;
												color: Palette.foreground;
											}
											Slider {
												minimum: 8;
												maximum: 24;
												step: 1;
												horizontal-stretch: 1;
												vertical-stretch: 0;
												value <=> AppLogic.response-body-font-size;
												changed => {
													AppLogic.commit-response-font-size(AppLogic.response-body-font-size);
												}
											}
										}
										RectButton {
											text: "Done";
											clicked => {
												response-font-settings-popup.close();
											}
										}
									}
								}
							}
						}
					}

					HorizontalBox {
						padding: 0px;
						spacing: 8px;
						Text {
							text: "Status: ";
							font-weight: 600;
							vertical-alignment: center;
						}
						Text {
							text: AppLogic.response-status;
							overflow: elide;
							horizontal-stretch: 1;
							vertical-alignment: center;
						}
						Text {
							text: AppLogic.request-elapsed == "" ? "" : "Elapsed " + AppLogic.request-elapsed;
							font-size: 11px;
							color: Palette.foreground;
							vertical-alignment: center;
							horizontal-stretch: 0;
						}
					}

					VerticalBox {
						vertical-stretch: 1;
						spacing: 4px;
						padding-top: 0px;
						padding-bottom: 0px;
						padding-left: 0px;
						padding-right: 0px;

						VerticalBox {
							height: response-headers-panel-height;
							vertical-stretch: 0;
							spacing: 4px;
							padding: 0px;

							Text {
								text: "Response headers";
								font-size: 11px;
								vertical-stretch: 0;
							}
							// TextEdit (read-only) sizes the inner ScrollView viewport from TextInput layout; plain Text in ScrollView does not scroll reliably.
							TextEdit {
								read-only: true;
								text: AppLogic.response-headers;
								font-family: AppLogic.response-body-font-family;
								font-size: AppLogic.response-body-font-size * 1px;
								wrap: word-wrap;
								vertical-stretch: 1;
								min-height: 40px;
							}
						}

						HorizontalSplitter {
							panel-height <=> response-headers-panel-height;
							min-panel-height: 72px;
							max-panel-height: 10000px;
						}

						VerticalBox {
							vertical-stretch: 1;
							spacing: 4px;
							padding: 0px;

							Text {
								text: "JSONPath";
								font-size: 11px;
							}
							CompactLineEdit {
								font-family: AppLogic.response-body-font-family;
								font-size: AppLogic.response-body-font-size * 1px;
								placeholder-text: "$.data.items[*].id";
								text <=> AppLogic.response-jsonpath;
								edited => {
									AppLogic.response-jsonpath-changed();
								}
							}

							HorizontalBox {
								padding: 0px;
								spacing: 6px;
								vertical-stretch: 0;
								Text {
									text: "Response body";
									font-size: 11px;
									vertical-alignment: center;
									horizontal-stretch: 1;
								}
								IconRectButton {
									vertical-stretch: 0;
									icon: @image-url("icons/copy.svg");
									clicked => {
										AppLogic.copy-response-body();
									}
								}
							}
							response-body-wheel-scope := TouchArea {
								vertical-stretch: 1;
								min-height: 80px;
								scroll-event(event) => {
									if (event.modifiers.control) {
										if (event.delta-y < 0) {
											AppLogic.adjust-response-font-size(1);
											return accept;
										}
										if (event.delta-y > 0) {
											AppLogic.adjust-response-font-size(-1);
											return accept;
										}
									}
									reject
								}
								ResponseBodyViewer {
									lines: AppLogic.response-body-lines;
									font-family: AppLogic.response-body-font-family;
									font-size: AppLogic.response-body-font-size * 1px;
									vertical-stretch: 1;
									min-height: 80px;
								}
							}
						}
					}
				}
			}
		}
		}

		}

		if AppLogic.collection-delete-dialog-open: Rectangle {
			width: 100%;
			height: 100%;
			// Opaque dim (ARGB alpha 0xFF); blocks the window behind.
			background: #FF000000;

			backdrop-dismiss := TouchArea {
				width: 100%;
				height: 100%;
				clicked => {
					AppLogic.collection-delete-dialog-cancel();
				}
			}

			Rectangle {
				x: (parent.width - self.width) / 2;
				y: (parent.height - self.height) / 2;
				width: min(parent.width - 48px, 420px);
				height: min(parent.height - 48px, 240px);
				background: Palette.control-background.mix(Palette.background, 0.015);
				border-width: 1px;
				border-color: Palette.border;
				border-radius: 8px;
				clip: true;

				VerticalBox {
					padding: 16px;
					spacing: 14px;
					vertical-stretch: 1;
					Text {
						text: AppLogic.collection-delete-dialog-text;
						wrap: word-wrap;
						font-size: 13px;
						color: Palette.foreground;
						width: 100%;
						vertical-stretch: 1;
					}
					HorizontalBox {
						spacing: 8px;
						alignment: end;
						if AppLogic.collection-delete-dialog-info-only: RectButton {
							text: "OK";
							clicked => {
								AppLogic.collection-delete-dialog-confirm();
							}
						}
						if !AppLogic.collection-delete-dialog-info-only: RectButton {
							text: "Cancel";
							clicked => {
								AppLogic.collection-delete-dialog-cancel();
							}
						}
						if !AppLogic.collection-delete-dialog-info-only: RectButton {
							text: "Delete";
							primary: true;
							clicked => {
								AppLogic.collection-delete-dialog-confirm();
							}
						}
					}
				}
			}
		}
	}
}
