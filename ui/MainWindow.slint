import { VerticalBox, HorizontalBox, LineEdit, ScrollView, Button, ComboBox, TextEdit, GridBox } from "std-widgets.slint";

export global AppLogic {
  callback send-request();
  callback cancel-request();
  in-out property <string> method: "GET";
  in-out property <string> url: "";
  in-out property <string> request-headers: "";
  in-out property <string> request-body: "";
  in property <string> response-status: "";
  in property <string> response-headers: "";
  in property <string> response-body: "";
  in property <bool> loading: false;
}

export component MainWindow inherits Window {
  title: "APIkulture";
  width: 900px;
  height: 700px;

  VerticalBox {
    padding: 8px;
    spacing: 8px;

    // --- Request section ---
    Text {
      text: "Request";
      font-size: 16px;
      font-weight: 700;
    }

    HorizontalBox {
      spacing: 8px;
      alignment: start;

      ComboBox {
        current-value <=> AppLogic.method;
        model: ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"];
        width: 120px;
      }

      LineEdit {
        placeholder-text: "https://api.example.com/endpoint";
        text <=> AppLogic.url;
        horizontal-stretch: 1;
        min-width: 200px;
      }

      Button {
        text: AppLogic.loading ? "Cancel" : "Send";
        primary: !AppLogic.loading;
        clicked => {
          if (AppLogic.loading) {
            AppLogic.cancel-request();
          } else {
            AppLogic.send-request();
          }
        }
      }
    }

    Text {
      text: "Headers (one per line: Key: value)";
      font-size: 12px;
    }
    ScrollView {
      max-height: 100px;
      TextEdit {
        text <=> AppLogic.request-headers;
        font-family: "monospace";
      }
    }

    Text {
      text: "Body";
      font-size: 12px;
    }
    ScrollView {
      vertical-stretch: 1;
      min-height: 120px;
      TextEdit {
        text <=> AppLogic.request-body;
        font-family: "monospace";
      }
    }

    // --- Response section ---
    Text {
      text: "Response";
      font-size: 16px;
      font-weight: 700;
    }

    HorizontalBox {
      Text {
        text: "Status: ";
        font-weight: 600;
      }
      Text {
        text: AppLogic.response-status;
      }
    }

    Text {
      text: "Response headers";
      font-size: 12px;
    }
    ScrollView {
      max-height: 80px;
      TextEdit {
        text: AppLogic.response-headers;
        read-only: true;
        font-family: "monospace";
      }
    }

    Text {
      text: "Response body";
      font-size: 12px;
    }
    ScrollView {
      vertical-stretch: 1;
      min-height: 150px;
      TextEdit {
        text: AppLogic.response-body;
        read-only: true;
        font-family: "monospace";
      }
    }
  }
}
